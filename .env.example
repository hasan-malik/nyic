# ─────────────────────────────────────────────────────────────────────────
# #IChooseNY — environment variables
#
# The app runs fully in DEMO MODE with NONE of these set (seeded data, no
# network). Add the two VITE_ vars below to switch the frontend to live
# Supabase. The remaining keys are SERVER-SIDE only (Edge Function secrets) —
# never expose them in the frontend.
# ─────────────────────────────────────────────────────────────────────────

# ── Frontend (safe to ship; the anon key is public by design + protected by RLS)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Edge Function secrets (set via: supabase secrets set KEY=value)
#    NOT prefixed with VITE_ — these never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ELEVENLABS_API_KEY=your-elevenlabs-key      # Scribe = multilingual speech-to-text
ANTHROPIC_API_KEY=your-anthropic-key        # Claude Haiku (care check) + Sonnet (tagging)
OPENAI_API_KEY=your-openai-key              # text-embedding-3-small (pgvector) + Whisper fallback
